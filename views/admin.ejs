<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin</title>

    <!-- Scripts -->
    <script src="//code.jquery.com/jquery-3.7.1.js"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>
    <!-- Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css">
</head>
<body>
    <table id="order-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Toppings</th>
            <th>Size</th>
            <th>Method</th>
            <th>Comment</th>
            <th>Timestamp</th>
        </tr>
    </thead>
    <% orders.forEach(order => { %>
        <tr>
            <td><%= order.fname %> <%= order.lname %></td>
            <td><%= order.email %></td>
            <td><%= order.method %></td>
            <td>
            <%= Array.isArray(order.toppings) ?
                order.toppings.join(", "):
                "No toppings" %></td>
            <td><%= order.size %></td>
            <td><%= order.comment %></td>
            <td><%= order.timestamp.toLocaleString() %></td>
        </tr>
    <% }) %>
    </table>
    <script defer>
        let table = new DataTable("#order-table");
    </script>
</body>
</html>